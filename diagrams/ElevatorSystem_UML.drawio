<mxfile host="app.diagrams.net">
  <diagram name="Elevator System" id="elevator-system">
    <mxGraphModel dx="1434" dy="844" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        
        <!-- Core Entities -->
        <mxCell id="elevator" value="Elevator&#xa;---&#xa;- manager: ElevatorManager&#xa;- state: State&#xa;- currentFloor: int&#xa;- queue: Queue&lt;Integer&gt;&#xa;---&#xa;+ Elevator(floor, manager)&#xa;+ addToQueue(floor): void&#xa;+ processQueue(): void&#xa;+ setState(state): void" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="240" height="160" as="geometry" />
        </mxCell>
        
        <mxCell id="elevatorManager" value="ElevatorManager&#xa;---&#xa;- panels: List&lt;OuterPanel&gt;&#xa;- elevators: List&lt;Elevator&gt;&#xa;- strategy: ElevatorSelectionStrategy&#xa;- observers: List&lt;ElevatorObserver&gt;&#xa;---&#xa;+ ElevatorManager(strategy)&#xa;+ notifyObservers(Elevator): void&#xa;+ addToQueue(floor, direction): void&#xa;+ addElevator(Elevator): void&#xa;+ addPanels(OuterPanel): void&#xa;&#xa;⭐ Observer Pattern (Subject)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="340" y="40" width="280" height="200" as="geometry" />
        </mxCell>
        
        <!-- Enum -->
        <mxCell id="direction" value="&lt;&lt;enum&gt;&gt;&#xa;Direction&#xa;---&#xa;UP&#xa;DOWN" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="680" y="40" width="120" height="80" as="geometry" />
        </mxCell>
        
        <!-- State Pattern -->
        <mxCell id="state" value="&lt;&lt;interface&gt;&gt;&#xa;State&#xa;---&#xa;+ moveUp(): void&#xa;+ moveDown(): void&#xa;+ stop(): void&#xa;&#xa;⭐ State Pattern" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="200" height="120" as="geometry" />
        </mxCell>
        
        <mxCell id="idleState" value="IdleState&#xa;---&#xa;- elevator: Elevator&#xa;---&#xa;+ moveUp(): void&#xa;+ moveDown(): void&#xa;+ stop(): void" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="180" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="moveUpState" value="MoveUpState&#xa;---&#xa;- elevator: Elevator&#xa;---&#xa;+ moveUp(): void&#xa;+ moveDown(): void&#xa;+ stop(): void" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="240" y="430" width="180" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="moveDownState" value="MoveDownState&#xa;---&#xa;- elevator: Elevator&#xa;---&#xa;+ moveUp(): void&#xa;+ moveDown(): void&#xa;+ stop(): void" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="440" y="430" width="180" height="100" as="geometry" />
        </mxCell>
        
        <!-- Strategy Pattern -->
        <mxCell id="selectionStrategy" value="&lt;&lt;interface&gt;&gt;&#xa;ElevatorSelectionStrategy&#xa;---&#xa;+ select(elevators, floor, direction): Elevator&#xa;&#xa;⭐ Strategy Pattern" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="680" y="260" width="300" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="nearestStrategy" value="NearestElevatorStrategy&#xa;---&#xa;+ select(elevators, floor, direction): Elevator&#xa;&#xa;Logic: Find elevator with min distance" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="680" y="410" width="280" height="90" as="geometry" />
        </mxCell>
        
        <mxCell id="loadBalancingStrategy" value="LoadBalancingSelectionStrategy&#xa;---&#xa;- random: Random&#xa;---&#xa;+ select(elevators, floor, direction): Elevator&#xa;&#xa;Logic: Random selection for load balancing" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1000" y="410" width="300" height="100" as="geometry" />
        </mxCell>
        
        <!-- Observer Pattern -->
        <mxCell id="elevatorObserver" value="&lt;&lt;interface&gt;&gt;&#xa;ElevatorObserver&#xa;---&#xa;+ update(Elevator): void&#xa;&#xa;⭐ Observer Pattern" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="680" y="570" width="200" height="100" as="geometry" />
        </mxCell>
        
        <mxCell id="outerPanel" value="OuterPanel&#xa;---&#xa;- manager: ElevatorManager&#xa;- floor: int&#xa;---&#xa;+ update(Elevator): void&#xa;+ requestElevator(Direction): void&#xa;&#xa;Observer + UI Component" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="920" y="570" width="240" height="120" as="geometry" />
        </mxCell>
        
        <!-- Relationships -->
        <!-- Elevator has State -->
        <mxCell id="arrow1" value="" style="endArrow=diamondThin;endFill=0;endSize=12;" edge="1" parent="1" source="elevator" target="state">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="140" y="220" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="label1" value="has" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="145" y="215" width="30" height="20" as="geometry" />
        </mxCell>
        
        <!-- State implementations -->
        <mxCell id="arrow2" value="" style="endArrow=block;dashed=1;endFill=0;endSize=12;" edge="1" parent="1" source="idleState" target="state">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="130" y="400" />
