        <!-- Legend -->
        <mxCell id="legend" value="Design Patterns:&#xa;⭐ State Pattern - Elevator states (Idle, MoveUp, MoveDown)&#xa;⭐ Strategy Pattern - Elevator selection (Nearest, LoadBalancing)&#xa;⭐ Observer Pattern - ElevatorManager notifies OuterPanels&#xa;&#xa;Key Flow:&#xa;1. OuterPanel.requestElevator(direction)&#xa;2. Manager uses Strategy to select elevator&#xa;3. Elevator processes queue with State transitions&#xa;4. Manager notifies all Observers (OuterPanels)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="580" width="380" height="150" as="geometry" />
        </mxCell>
        
      </root>
