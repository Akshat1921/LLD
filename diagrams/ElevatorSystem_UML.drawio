              <mxPoint x="640" y="240" />
              <mxPoint x="580" y="240" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Elevator has reference to Manager -->
        <mxCell id="arrow12" value="" style="endArrow=open;endSize=12;" edge="1" parent="1" source="elevator" target="elevatorManager">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="300" y="80" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- OuterPanel uses Direction -->
        <mxCell id="arrow13" value="" style="endArrow=open;endSize=12;" edge="1" parent="1" source="outerPanel" target="direction">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1040" y="540" />
