        <mxCell id="arrow4" value="" style="endArrow=block;dashed=1;endFill=0;endSize=12;" edge="1" parent="1" source="moveDownState" target="state">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="530" y="400" />
              <mxPoint x="200" y="400" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- ElevatorManager has Strategy -->
        <mxCell id="arrow5" value="" style="endArrow=diamondThin;endFill=0;endSize=12;" edge="1" parent="1" source="elevatorManager" target="selectionStrategy">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="620" y="140" />
              <mxPoint x="780" y="260" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Strategy implementations -->
        <mxCell id="arrow6" value="" style="endArrow=block;dashed=1;endFill=0;endSize=12;" edge="1" parent="1" source="nearestStrategy" target="selectionStrategy">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="820" y="380" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="arrow7" value="" style="endArrow=block;dashed=1;endFill=0;endSize=12;" edge="1" parent="1" source="loadBalancingStrategy" target="selectionStrategy">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1150" y="380" />
              <mxPoint x="900" y="380" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- ElevatorManager manages Elevators -->
        <mxCell id="arrow8" value="manages" style="endArrow=open;endSize=12;" edge="1" parent="1" source="elevatorManager" target="elevator">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="300" y="120" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- ElevatorManager notifies Observers -->
        <mxCell id="arrow9" value="notifies" style="endArrow=open;dashed=1;endSize=12;" edge="1" parent="1" source="elevatorManager" target="elevatorObserver">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
