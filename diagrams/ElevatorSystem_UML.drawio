              <mxPoint x="480" y="540" />
              <mxPoint x="780" y="540" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- OuterPanel implements Observer -->
        <mxCell id="arrow10" value="" style="endArrow=block;dashed=1;endFill=0;endSize=12;" edge="1" parent="1" source="outerPanel" target="elevatorObserver">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="900" y="630" />
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- OuterPanel uses ElevatorManager -->
        <mxCell id="arrow11" value="requests" style="endArrow=open;dashed=1;endSize=12;" edge="1" parent="1" source="outerPanel" target="elevatorManager">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1040" y="540" />
