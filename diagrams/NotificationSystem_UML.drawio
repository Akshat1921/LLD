        </mxCell>
        
        <!-- Factory Pattern -->
        <mxCell id="notificationFactory" value="NotificationFactory&#xa;---&#xa;+ getChannel(ChannelType): NotificationChannel&#xa;&#xa;⭐ Factory Pattern" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="600" y="340" width="280" height="90" as="geometry" />
        </mxCell>
        
        <!-- Services -->
        <mxCell id="userPreferenceService" value="UserPreferenceService&#xa;---&#xa;- preferences: Map&lt;String, UserPreference&gt;&#xa;---&#xa;+ savePreference(UserPreference): void&#xa;+ getPreference(userId): UserPreference" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
