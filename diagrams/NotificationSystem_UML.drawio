        </mxCell>
        
        <mxCell id="notificationDispatcher" value="NotificationDispatcher&#xa;---&#xa;- preferenceService: UserPreferenceService&#xa;---&#xa;+ NotificationDispatcher(preferenceService)&#xa;+ dispatch(Notification): void" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
