        </mxCell>
        
        <mxCell id="userPreference" value="UserPreference&#xa;---&#xa;- userId: String&#xa;- preferredChannel: Set&lt;ChannelType&gt;&#xa;---&#xa;+ UserPreference(userId, channels)&#xa;+ getUserId(): String&#xa;+ getPreferredChannel(): Set&lt;ChannelType&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
